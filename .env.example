# Backend
# Local development uses Ollama with deepseek-coder for repair/code generation.
# Set LLM_PROVIDER to one of: anthropic, openai, gemini, ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Model that Ollama will pull and the backend will call.
LLM_MODEL_OLLAMA=deepseek-coder:latest

# Only needed when using the respective cloud providers.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

LLM_MODEL_ANTHROPIC=claude-sonnet-4-6
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_GEMINI=gemini-1.5-flash

LLM_TIMEOUT_SECONDS=120
CORS_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000
